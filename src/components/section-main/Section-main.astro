---
import "./Section-main.scss";
---

<div class="container">
  <header>
    <div class="brand">
      <div
        class="logo"
        style="font-family: 'CMU Typewriter Text', monospace; font-size: 2rem;"
      >
        Z
      </div>
      <span
        style="font-weight: 700; font-size: 1.25rem; font-family: 'CMU Typewriter Text', monospace;"
        >Zentry</span
      >
    </div>
    <nav>
      <a class="ghost" href="#services">Servicios</a>
      <a class="ghost" href="#portafolio">Casos</a>
      <!-- <a class="btn" href="#contacto">Agendar</a> -->
    </nav>
  </header>
  <div class="welcome-image">
    <img
      src="/images/edificio-nubes-pro.webp"
      alt="Ilustración de bienvenida"
      loading="lazy"
    />
    <!-- overlay phrase -->
    <div class="image-overlay" aria-hidden="false">
      <h2 class="overlay-phrase">Impulsamos tu empresa hasta las nubes</h2>
    </div>
  </div>
  <section class="hero">
    <div>
      <div class="card">
        <h1>Te ayudamos a construir y/o mejorar tus necesidades digitales.</h1>
        <p class="lead">
          Diseño y desarrollo web y móvil, arquitectura en AWS, automatización y
          soporte para equipos que quieren ir rápido — sin romper cosas.
        </p>
        <!-- <div style="display:flex;gap:12px">
          <a class="btn" href="#contacto">Solicitar demo</a>
          <a class="ghost" href="#portafolio">Ver casos</a>
        </div> -->
        <div class="kpis" aria-hidden>
          <div class="kpi">
            <strong>+5</strong><span class="muted">Empresas</span>
          </div>
          <div class="kpi">
            <strong>99%</strong><span class="muted">SLA</span>
          </div>
          <div class="kpi">
            <strong>3x</strong><span class="muted">Velocidad</span>
          </div>
        </div>
      </div>
    </div>

    <aside>
      <div class="card" id="services">
        <h3>¿Qué ofrecemos?</h3>
        <ul style="padding:0;margin:12px 0 0;list-style:none">
          <li>Desarrollo Web & PWAs</li>
          <li>Apps móviles (iOS & Android)</li>
          <li>Infraestructura en AWS (IaC, CI/CD)</li>
          <li>Consultoría DevOps y SRE</li>
        </ul>
      </div>

      <div style="height:18px"></div>

      <div class="card">
        <h4>Empieza hoy</h4>
        <p class="lead">
          Sesiónes gratuitas por Google Meet para conocer tus necesidades y
          objetivos, para definir el alcance y plan de acción.
        </p>
        <!-- <a class="btn" href="#contacto">Agendar</a> -->
      </div>
    </aside>
  </section>

  <section class="two">
    <div class="card">
      <h3>Cómo trabajamos</h3>
      <ul class="features">
        <li><strong>Discovery</strong> — Objetivos, métricas, MVP.</li>
        <li><strong>Diseño</strong> — UX, UI, prototipos interactivos.</li>
        <li>
          <strong>Build</strong> — Entregas incrementales y código probado.
        </li>
        <li><strong>Operate</strong> — Monitoreo, alertas y soporte.</li>
      </ul>
    </div>
    <div class="card">
      <h3>Casos de éxito</h3>
      <div class="portfolio" id="portafolio">
        <div class="shot">
          <h4>E-commerce "La vieja"</h4>
          <a href="https://lavieja.pe" target="_blank" rel="noopener noreferrer"
            >lavieja.pe</a
          >
        </div>
        <div class="shot">
          <h4>Fintech App "Xhu capital"</h4>
          <p class="muted">Hackton fin 4 all 2025</p>
        </div>
        <div class="shot">
          <h4>CRM "Sistemas cúbicos"</h4>
          <a
            href="https://sistema2.smuebleria.com"
            target="_blank"
            rel="noopener noreferrer">sistema2.smuebleria.com</a
          >
        </div>
        <div class="shot">
          <h4>App de logística "Navi"</h4>
          <p class="muted">Plataforma interna</p>
        </div>
      </div>
    </div>
  </section>

  <!-- <section id="contacto" class="card">
    <h3>Contacto</h3>
    <p class="muted">Escríbenos y te respondemos en 24 horas hábiles.</p>
    <form action="/api/contact" method="post">
      <input name="name" placeholder="Nombre" required />
      <input name="email" placeholder="Email" type="email" required />
      <input name="company" placeholder="Empresa (opcional)" />
      <select name="service">
        <option value="web">Desarrollo web</option>
        <option value="mobile">Apps móviles</option>
        <option value="cloud">Nube & AWS</option>
      </select>
      <textarea name="message" placeholder="Cuéntanos brevemente tu proyecto"
      ></textarea>
      <div class="form-footer">
        <button type="submit" class="btn">Enviar</button>
      </div>
    </form>
  </section> -->
  <div class="contacto-btn-container" aria-hidden="false">
    <a
      href="https://wa.me/524428549509"
      class="contacto-btn"
      id="contacto-btn"
      aria-label="Contactarnos por WhatsApp"
    >
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
        <path
          d="M20.52 3.48A11.93 11.93 0 0 0 12 0C5.37 0 0 5.37 0 12c0 2.11.55 4.17 1.6 6.01L0 24l6.18-1.62A11.93 11.93 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.19-1.24-6.19-3.48-8.52zM12 22c-1.85 0-3.67-.5-5.23-1.45l-.37-.22-3.67.96.98-3.58-.24-.37A9.93 9.93 0 0 1 2 12c0-5.52 4.48-10 10-10s10 4.48 10 10-4.48 10-10 10zm5.2-7.8c-.28-.14-1.65-.81-1.9-.9-.25-.09-.43-.14-.61.14-.18.28-.7.9-.86 1.08-.16.18-.32.2-.6.07-.28-.14-1.18-.44-2.25-1.41-.83-.74-1.39-1.65-1.55-1.93-.16-.28-.02-.43.12-.57.13-.13.28-.34.42-.51.14-.17.18-.29.28-.48.09-.19.05-.36-.02-.5-.07-.14-.61-1.47-.84-2.01-.22-.53-.45-.46-.61-.47-.16-.01-.35-.01-.54-.01-.19 0-.5.07-.76.34-.26.27-1 1-.98 2.43.02 1.43 1.03 2.81 1.18 3.01.15.2 2.03 3.1 4.93 4.22.69.3 1.23.48 1.65.61.69.22 1.32.19 1.82.12.56-.08 1.65-.67 1.89-1.32.23-.65.23-1.21.16-1.32-.07-.11-.25-.18-.53-.32z"
        ></path>
      </svg>
    </a>
  </div>

  <footer>
    <div>
      © {new Date().getFullYear()} Startup Tech — Todos los derechos reservados
    </div>
    <div style="display:flex;gap:12px">
      <a class="ghost" href="#" id="open-terms">Términos</a>
      <a class="ghost" href="#" id="open-privacy">Privacidad</a>
    </div>
  </footer>

  <!-- Modales -->
  <div
    id="modal-terms"
    class="modal-overlay"
    tabindex="-1"
    aria-modal="true"
    style="display:none"
  >
    <div class="modal-content">
      <button class="modal-close" id="close-terms" aria-label="Cerrar">×</button
      >
      <h2>Términos</h2>
      <p>Aquí van los términos de uso de tu sitio...</p>
    </div>
  </div>
  <div
    id="modal-privacy"
    class="modal-overlay"
    tabindex="-1"
    aria-modal="true"
    style="display:none"
  >
    <div class="modal-content">
      <button class="modal-close" id="close-privacy" aria-label="Cerrar"
        >×</button
      >
      <h2>Privacidad</h2>
      <p>Aquí va la política de privacidad de tu sitio...</p>
    </div>
  </div>

  <style>
    /* fixed bottom-right floating button */
    .contacto-btn-container {
      position: fixed;
      bottom: 20px;
      right: 20px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      z-index: 9999;
      pointer-events: auto;
    }

    /* make it slightly smaller on small screens */
    @media (max-width: 480px) {
      .contacto-btn-container {
        bottom: 5dvh;
        right: 10%;
      }
      .contacto-btn {
        padding: 0.45rem 0.9rem;
        font-size: 0.9rem;
      }
    }
    @media (max-width: 768px) {
      .servicio-card:nth-child(n + 4) {
        display: none;
      }
    }
    .contacto-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1.1rem;
      background-color: #22c55e;
      color: #fff;
      font-weight: 700;
      font-size: 1rem;
      border-radius: 0.6rem;
      box-shadow: 0 6px 12px -3px rgba(0, 0, 0, 0.22);
      transition: all 0.3s ease;
    }

    .contacto-btn:hover {
      background-color: #16a34a;
    }

    .contacto-btn:focus {
      outline: none;
      box-shadow: 0 0 0 4px rgba(74, 222, 128, 0.5);
    }

    .animate-bounce-on-view {
      animation: bounceOnView 1s infinite;
    }

    @keyframes bounceOnView {
      0%,
      100% {
        transform: translateY(0);
        animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
      }
      50% {
        transform: translateY(-10px);
        animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
      }
    }

    .contacto-btn svg {
      width: clamp(1.2rem, 4vw, 1.75rem);
      height: clamp(1.2rem, 4vw, 1.75rem);
    }

    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 99999;
    }
    .modal-content {
      background: #fff;
      border-radius: 1rem;
      padding: 2rem 1.5rem;
      max-width: 400px;
      width: 90vw;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
      position: relative;
      text-align: left;
    }
    .modal-content h2 {
      margin-top: 0;
      font-size: 1.3rem;
      color: #2563eb;
    }
    .modal-content p {
      font-size: 1rem;
      color: #222;
      margin-bottom: 0;
    }
    .modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 1.5rem;
      color: #2563eb;
      cursor: pointer;
      font-weight: bold;
    }
  </style>
</div>
