---
import "./Section-main.scss";
---

<div class="container">
  <section id="servicios">
    <h2 style="margin:8px 0 16px">Servicios principales</h2>
    <div class="services">
      <div class="service card">
        <h3>Desarrollo Web</h3>
        <p class="muted">
          React, Next.js, Astro, integración CMS, performance y accesibilidad.
        </p>
      </div>
      <div class="service card">
        <h3>Apps Móviles</h3>
        <p class="muted">
          React Native, consultoría de producto y pipelines de release.
        </p>
      </div>
      <div class="service card">
        <h3>Nube & AWS</h3>
        <p class="muted">
          Arquitectura, infra as code (Terraform, CDK), optimización de costes y
          seguridad.
        </p>
      </div>
    </div>
  </section>
</div>
